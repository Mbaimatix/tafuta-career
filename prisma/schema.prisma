generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pathway {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  description String
  icon        String
  color       String     @default("#006600")
  subTracks   SubTrack[]
}

model SubTrack {
  id          Int      @id @default(autoincrement())
  pathwayId   Int
  name        String
  code        String   @unique
  description String
  pathway     Pathway  @relation(fields: [pathwayId], references: [id])
  careers     Career[]
}

model Career {
  id                 Int             @id @default(autoincrement())
  subTrackId         Int
  number             Int
  name               String
  subjects           String
  description        String
  salaryRangeKsh     String
  growthOutlook      String
  requiresUniversity Boolean         @default(true)
  subTrack           SubTrack        @relation(fields: [subTrackId], references: [id])
  careerSubjects     CareerSubject[]
}

model Subject {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  pathwayAffinity String
  careerSubjects  CareerSubject[]
}

model CareerSubject {
  careerId  Int
  subjectId Int
  career    Career  @relation(fields: [careerId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@id([careerId, subjectId])
}
