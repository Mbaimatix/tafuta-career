# ═══════════════════════════════════════════════════════════════════════════════
# TAFUTA CAREER — Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local — it is already in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Prisma / SQLite (not used at runtime — static data only)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────────────────────────────────────
# Safaricom Daraja API — M-Pesa STK Push
# Get consumer key + secret from https://developer.safaricom.co.ke after
# creating a "Lipa Na M-Pesa Online" Daraja app.
# ─────────────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=GET_FROM_DARAJA_PORTAL
MPESA_CONSUMER_SECRET=GET_FROM_DARAJA_PORTAL

# Sandbox test values (Safaricom official):
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# For local dev: run `ngrok http 3000` and paste the https URL below
# For Vercel production: use https://tafutacareer.com
MPESA_CALLBACK_URL=https://PASTE_YOUR_NGROK_OR_PRODUCTION_URL_HERE/api/mpesa/callback

# Set to "production" when going live; leave as "sandbox" for testing
MPESA_ENV=sandbox

# ─────────────────────────────────────────────────────────────────────────────
# Vercel KV (Redis) — persistent payment results across serverless instances
# Create a KV store: vercel.com/dashboard → Storage → Create → KV
# then copy the four credentials from the "Quickstart" tab.
# ─────────────────────────────────────────────────────────────────────────────
KV_URL=redis://default:TOKEN@REGION.upstash.io:PORT
KV_REST_API_URL=https://REGION.upstash.io
KV_REST_API_TOKEN=YOUR_KV_REST_API_TOKEN
KV_REST_API_READ_ONLY_TOKEN=YOUR_KV_READ_ONLY_TOKEN
